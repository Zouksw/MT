generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(uuid())
  email                String                 @unique
  passwordHash         String                 @map("password_hash")
  name                 String
  avatarUrl            String?                @map("avatar_url")
  role                 UserRole               @default(VIEWER)
  is_mfa_enabled       Boolean                @default(false)
  mfa_secret           String?
  preferences          Json?
  lastLoginAt          DateTime?              @map("last_login_at")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime?              @updatedAt @map("updated_at")
  failedLoginAttempts  Int?                   @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime?              @map("locked_until") @db.Timestamp(6)
  alerts               Alert[]
  alertRules           AlertRule[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  datasets             Dataset[]
  models               ForecastingModel[]
  organization_members organization_members[]
  organizations        organizations[]
  saved_queries        saved_queries[]
  securityAuditLogs    SecurityAuditLog[]     @relation("SecurityAuditLogs")
  sessions             Session[]
  watchlists           Watchlist[]
  portfolios           Portfolio[]
  simAccounts          SimulationAccount[]
  sharedSignals        SharedSignal[]
  signalComments       SignalComment[]
  signalLikes          SignalLike[]
  subscription         Subscription?

  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model Dataset {
  id              String        @id @default(uuid())
  organization_id String
  ownerId         String        @map("owner_id")
  name            String
  slug            String
  description     String?
  commodityType   String?       @map("commodity_type")
  storageFormat   StorageFormat @map("storage_format")
  filePath        String?       @map("file_path")
  sizeBytes       BigInt?       @map("size_bytes")
  rowsCount       Int?          @map("rows_count")
  metadata        Json?
  isPublic        Boolean       @default(false) @map("is_public")
  isImported      Boolean       @default(false) @map("is_imported")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime?     @updatedAt @map("updated_at")
  lastAccessedAt  DateTime?     @map("last_accessed_at")
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  owner           User          @relation(fields: [ownerId], references: [id])
  timeseries      Timeseries[]

  @@unique([organization_id, slug])
  @@index([ownerId])
  @@index([createdAt(sort: Desc)])
  @@map("datasets")
}

model Timeseries {
  id                        String             @id @default(uuid())
  datasetId                 String             @map("dataset_id")
  name                      String
  slug                      String
  description               String?
  colorHex                  String?            @map("color_hex")
  unit                      String?
  timezone                  String             @default("UTC")
  isAnomalyDetectionEnabled Boolean            @default(false) @map("is_anomaly_detection_enabled")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime?          @updatedAt @map("updated_at")
  alerts                    Alert[]
  anomalies                 Anomaly[]
  dataPoints                Datapoint[]
  models                    ForecastingModel[]
  forecasts                 Forecast[]
  dataset                   Dataset            @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, slug])
  @@index([createdAt(sort: Desc)])
  @@map("timeseries")
}

model Datapoint {
  id           String     @id @default(uuid())
  timeseriesId String     @map("timeseries_id")
  timestamp    DateTime
  valueJson    Json       @map("value_json")
  qualityScore Decimal?   @map("quality_score") @db.Decimal(3, 2)
  isOutlier    Boolean    @default(false) @map("is_outlier")
  isAnomaly    Boolean    @default(false) @map("is_anomaly")
  createdAt    DateTime   @default(now()) @map("created_at")
  timeseries   Timeseries @relation(fields: [timeseriesId], references: [id], onDelete: Cascade)

  @@index([timeseriesId, timestamp(sort: Desc)])
  @@index([timeseriesId, isAnomaly])
  @@index([timestamp(sort: Desc)]) // NEW: For time-range queries
  @@index([timeseriesId, isOutlier]) // NEW: For outlier detection
  @@map("datapoints")
}

model ForecastingModel {
  id              String         @id @default(uuid())
  timeseriesId    String         @map("timeseries_id")
  trainedById     String?        @map("trained_by_id")
  algorithm       ModelAlgorithm
  hyperparameters Json
  trainingMetrics Json?          @map("training_metrics")
  version         Int            @default(1)
  isActive        Boolean        @default(true) @map("is_active")
  trainedAt       DateTime?      @map("trained_at")
  deployedAt      DateTime?      @map("deployed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  timeseries      Timeseries     @relation(fields: [timeseriesId], references: [id], onDelete: Cascade)
  trainedBy       User?          @relation(fields: [trainedById], references: [id])
  forecasts       Forecast[]

  @@index([timeseriesId])
  @@index([trainedById])
  @@index([isActive])
  @@index([trainedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("forecasting_models")
}

model Forecast {
  id                 String           @id @default(uuid())
  modelId            String           @map("model_id")
  timeseriesId       String           @map("timeseries_id")
  timestamp          DateTime
  predictedValue     Decimal          @map("predicted_value") @db.Decimal(15, 6)
  lowerBound         Decimal?         @map("lower_bound") @db.Decimal(15, 6)
  upperBound         Decimal?         @map("upper_bound") @db.Decimal(15, 6)
  confidence         Decimal          @db.Decimal(3, 2)
  anomalyProbability Decimal?         @map("anomaly_probability") @db.Decimal(3, 2)
  isAnomaly          Boolean          @default(false) @map("is_anomaly")
  createdAt          DateTime         @default(now()) @map("created_at")
  model              ForecastingModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  timeseries         Timeseries       @relation(fields: [timeseriesId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([timeseriesId, timestamp(sort: Desc)])
  @@map("forecasts")
}

model Anomaly {
  id              String          @id @default(uuid())
  timeseriesId    String          @map("timeseries_id")
  datapointId     BigInt?         @map("datapoint_id")
  severity        AnomalySeverity
  detectionMethod DetectionMethod @map("detection_method")
  score           Decimal?        @db.Decimal(5, 2)
  context         Json?
  isInvestigated  Boolean         @default(false) @map("is_investigated")
  resolutionNotes String?         @map("resolution_notes")
  isResolved      Boolean         @default(false) @map("is_resolved")
  resolvedAt      DateTime?       @map("resolved_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  timeseries      Timeseries      @relation(fields: [timeseriesId], references: [id], onDelete: Cascade)

  @@index([timeseriesId])
  @@index([timeseriesId, severity])
  @@index([timeseriesId, isResolved])
  @@index([createdAt(sort: Desc)])
  @@map("anomalies")
}

model Alert {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  timeseriesId String        @map("timeseries_id")
  alertRuleId  String?       @map("alert_rule_id")
  type         AlertType
  severity     AlertSeverity
  message      String
  metadata     Json?
  isRead       Boolean       @default(false) @map("is_read")
  sentAt       DateTime?     @map("sent_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  timeseries   Timeseries    @relation(fields: [timeseriesId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertRule    AlertRule?    @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([timeseriesId])
  @@index([alertRuleId])
  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("alerts")
}

model AlertRule {
  id                String              @id @default(uuid())
  userId            String              @map("user_id")
  timeseriesId      String              @map("timeseries_id")
  name              String
  description       String?
  type              String              @default("ANOMALY")
  enabled           Boolean             @default(true)
  conditions        Json                @map("conditions")
  severity          String              @default("WARNING")
  channels          Json                @map("channels")
  cooldownMinutes   Int                 @default(5) @map("cooldown_minutes")
  lastTriggeredAt   DateTime?           @map("last_triggered_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime?           @updatedAt @map("updated_at")
  alerts            Alert[]
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timeseriesId])
  @@index([enabled])
  @@index([userId, enabled])
  @@map("alert_rules")
}

model ApiKey {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  name           String
  keyHash        String    @unique @map("key_hash")
  lastCharacters Int       @map("last_characters")
  isActive       Boolean   @default(true) @map("is_active")
  usageCount     Int       @default(0) @map("usage_count")
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("api_keys")
}

model Session {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  tokenHash      String    @map("token_hash")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  expiresAt      DateTime  @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([isActive])
  @@index([userId, createdAt(sort: Desc)])
  @@map("sessions")
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  action       AuditAction
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  success      Boolean
  errorCode    String?     @map("error_code")
  createdAt    DateTime    @default(now()) @map("created_at")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model SecurityAuditLog {
  id         String   @id @default(uuid())
  event      String
  timestamp  DateTime @default(now())
  userId     String?  @map("user_id")
  sessionId  String   @map("session_id")
  details    Json     @default("{}")
  severity   String
  userAgent  String?  @map("user_agent")
  url        String?
  receivedAt DateTime @default(now()) @map("received_at")
  user       User?    @relation("SecurityAuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([event, timestamp])
  @@index([severity, timestamp])
  @@index([timestamp])
  @@map("security_audit_logs")
}

model organization_members {
  id              String        @id
  organization_id String
  user_id         String
  role            UserRole      @default(VIEWER)
  created_at      DateTime      @default(now())
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id])
  @@index([user_id])
}

model organizations {
  id                   String                 @id
  owner_id             String
  name                 String
  slug                 String                 @unique
  description          String?
  logo_url             String?
  settings             Json?
  is_archived          Boolean                @default(false)
  created_at           DateTime               @default(now())
  updated_at           DateTime?
  datasets             Dataset[]
  organization_members organization_members[]
  users                User                   @relation(fields: [owner_id], references: [id], onDelete: Cascade)

  @@index([created_at(sort: Desc)])
  @@index([owner_id])
  @@index([slug])
}

model saved_queries {
  id              String    @id
  user_id         String
  organization_id String?
  name            String
  description     String?
  query_params    Json
  is_public       Boolean   @default(false)
  usage_count     Int       @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime?
  last_used_at    DateTime?
  users           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([user_id, created_at(sort: Desc)])
  @@index([user_id])
}

model PredictionLog {
  id              String    @id @default(uuid())
  modelId         String    @map("model_id")
  commodityId     String    @map("commodity_id")
  timeseriesPath  String    @map("timeseries_path")
  horizon         Int
  predictedValues Json      @map("predicted_values")
  actualValues    Json?     @map("actual_values")
  lowerBounds     Json?     @map("lower_bounds")
  upperBounds     Json?     @map("upper_bounds")
  confidence      Decimal?  @db.Decimal(3, 2)
  mape            Decimal?  @db.Decimal(5, 2)
  status          String    @default("pending")
  predictedAt     DateTime  @default(now()) @map("predicted_at")
  verifiedAt      DateTime? @map("verified_at")

  @@index([modelId])
  @@index([commodityId])
  @@index([predictedAt])
  @@map("prediction_logs")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum StorageFormat {
  IOTDB_CACHE
  INFLUXDB
  OPENML
  CSV
}

enum ModelAlgorithm {
  ARIMA
  PROPHET
  LSTM
  TRANSFORMER
  ENSEMBLE
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DetectionMethod {
  STATISTICAL
  ML_AUTOENCODER
  RULE_BASED
}

enum AlertType {
  ANOMALY
  FORECAST_READY
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  LOGIN
}

// ─── TradeMind AI: Commodity Trading Models ───

model Commodity {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  nameCn        String?  @map("name_cn")
  category      String   // beef_cuts, live_cattle, grain, feed, forex, etc.
  subcategory   String?  // brisket, shin, sirloin, thick_flank, etc.
  grade         String?  // Prime, Choice, Select, M9, M7, etc.
  originCountry String?  @map("origin_country") // AUS, BRA, ARG, URY, USA, CN
  factoryCode   String?  @map("factory_code")
  unit          String   // USD/kg, CNY/kg, USD/ton, etc.
  currency      String   @default("USD")
  isActive      Boolean  @default(true) @map("is_active")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  prices        CommodityPrice[]
  watchlistItems WatchlistItem[]
  positions     Position[]
  simOrders     SimulationOrder[]
  simTrades     SimulationTrade[]

  @@index([category])
  @@index([originCountry])
  @@index([isActive])
  @@map("commodities")
}

model CommodityPrice {
  id           String    @id @default(uuid())
  commodityId  String    @map("commodity_id")
  date         DateTime
  interval     String    // daily, weekly, monthly
  open         Decimal?  @db.Decimal(18, 6)
  high         Decimal?  @db.Decimal(18, 6)
  low          Decimal?  @db.Decimal(18, 6)
  close        Decimal   @db.Decimal(18, 6)
  volume       Decimal?  @db.Decimal(18, 4)
  source       String    // usda_ams, fao, cme, china_mara, china_customs, manual
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  commodity    Commodity @relation(fields: [commodityId], references: [id], onDelete: Cascade)

  @@unique([commodityId, interval, date, source])
  @@index([commodityId, interval, date(sort: Desc)])
  @@index([commodityId, date(sort: Desc)])
  @@map("commodity_prices")
}

model MarketFactor {
  id         String   @id @default(uuid())
  type       String   // weather, exchange_rate, tariff, shipping_cost, quota, policy
  region     String?
  date       DateTime
  value      Decimal  @db.Decimal(18, 6)
  unit       String
  source     String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([type, region, date])
  @@index([type, date(sort: Desc)])
  @@map("market_factors")
}

// ─── Phase 2: Watchlist & Portfolio ───

model Watchlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]

  @@unique([userId, name])
  @@index([userId])
  @@map("watchlists")
}

model WatchlistItem {
  id           String    @id @default(uuid())
  watchlistId  String    @map("watchlist_id")
  commodityId  String    @map("commodity_id")
  addedAt      DateTime  @default(now()) @map("added_at")
  notes        String?
  watchlist    Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  commodity    Commodity @relation(fields: [commodityId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, commodityId])
  @@index([watchlistId])
  @@map("watchlist_items")
}

model Portfolio {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions   Position[]

  @@unique([userId, name])
  @@index([userId])
  @@map("portfolios")
}

model Position {
  id             String     @id @default(uuid())
  portfolioId    String     @map("portfolio_id")
  commodityId    String     @map("commodity_id")
  side           String     @default("LONG") // LONG or SHORT
  quantity       Decimal    @db.Decimal(18, 6)
  avgEntryPrice  Decimal    @map("avg_entry_price") @db.Decimal(18, 6)
  currentPrice   Decimal?   @map("current_price") @db.Decimal(18, 6)
  unrealizedPnl  Decimal?   @map("unrealized_pnl") @db.Decimal(18, 6)
  realizedPnl    Decimal?   @map("realized_pnl") @db.Decimal(18, 6)
  openedAt       DateTime   @default(now()) @map("opened_at")
  closedAt       DateTime?  @map("closed_at")
  notes          String?
  portfolio      Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  commodity      Commodity  @relation(fields: [commodityId], references: [id])

  @@index([portfolioId])
  @@index([commodityId])
  @@map("positions")
}

// ─── Phase 3: Simulation Trading ───

model SimulationAccount {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  name            String
  initialBalance  Decimal             @map("initial_balance") @db.Decimal(18, 2)
  currentBalance  Decimal             @map("current_balance") @db.Decimal(18, 2)
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime?           @updatedAt @map("updated_at")
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          SimulationOrder[]
  trades          SimulationTrade[]

  @@index([userId])
  @@map("simulation_accounts")
}

model SimulationOrder {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  commodityId     String   @map("commodity_id")
  side            String   // BUY, SELL
  type            String   // MARKET, LIMIT, STOP
  quantity        Decimal  @db.Decimal(18, 6)
  price           Decimal? @db.Decimal(18, 6)
  stopPrice       Decimal? @map("stop_price") @db.Decimal(18, 6)
  status          String   @default("PENDING") // PENDING, FILLED, CANCELLED
  filledPrice     Decimal? @map("filled_price") @db.Decimal(18, 6)
  filledQuantity  Decimal? @map("filled_quantity") @db.Decimal(18, 6)
  commission      Decimal  @default(0) @db.Decimal(18, 4)
  placedAt        DateTime @default(now()) @map("placed_at")
  filledAt        DateTime? @map("filled_at")
  account         SimulationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  commodity       Commodity @relation(fields: [commodityId], references: [id])

  @@index([accountId])
  @@index([status])
  @@map("simulation_orders")
}

model SimulationTrade {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  commodityId     String   @map("commodity_id")
  orderId         String?  @map("order_id")
  side            String   // BUY, SELL
  quantity        Decimal  @db.Decimal(18, 6)
  entryPrice      Decimal  @map("entry_price") @db.Decimal(18, 6)
  exitPrice       Decimal? @map("exit_price") @db.Decimal(18, 6)
  realizedPnl     Decimal? @map("realized_pnl") @db.Decimal(18, 6)
  commission      Decimal  @default(0) @db.Decimal(18, 4)
  openedAt        DateTime @default(now()) @map("opened_at")
  closedAt        DateTime? @map("closed_at")
  account         SimulationAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  commodity       Commodity @relation(fields: [commodityId], references: [id])

  @@index([accountId])
  @@index([openedAt])
  @@map("simulation_trades")
}

// ─── Phase 6: Community & Social ───

model SharedSignal {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  commoditySlug   String   @map("commodity_slug")
  signalType      String   @map("signal_type") // BUY, SELL, HOLD
  confidence      Decimal  @db.Decimal(3, 2)
  reasoning       String?
  currentPrice    Decimal? @map("current_price") @db.Decimal(18, 6)
  targetPrice     Decimal? @map("target_price") @db.Decimal(18, 6)
  likes           Int      @default(0)
  commentsCount   Int      @default(0) @map("comments_count")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalComments  SignalComment[]
  signalLikes     SignalLike[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([commoditySlug])
  @@map("shared_signals")
}

model SignalComment {
  id         String       @id @default(uuid())
  signalId   String       @map("signal_id")
  userId     String       @map("user_id")
  content    String
  createdAt  DateTime     @default(now()) @map("created_at")
  signal     SharedSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@index([userId])
  @@map("signal_comments")
}

model SignalLike {
  id         String       @id @default(uuid())
  signalId   String       @map("signal_id")
  userId     String       @map("user_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  signal     SharedSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([signalId, userId])
  @@index([signalId])
  @@map("signal_likes")
}

// ─── Phase 7: Monetization ───

model Subscription {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  stripeCustomerId  String?  @map("stripe_customer_id")
  stripePriceId     String?  @map("stripe_price_id")
  stripeSubId       String?  @map("stripe_sub_id")
  plan              String   @default("free") // free, pro, enterprise
  status            String   @default("active") // active, past_due, canceled
  currentPeriodEnd  DateTime? @map("current_period_end")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords      UsageRecord[]

  @@unique([userId])
  @@index([stripeCustomerId])
  @@index([plan])
  @@map("subscriptions")
}

model UsageRecord {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  feature        String       // signals, watchlists, api_calls, etc.
  count          Int          @default(0)
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, feature, periodStart])
  @@index([subscriptionId])
  @@map("usage_records")
}
