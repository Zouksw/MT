{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "reporters": ["html", "clear-text", "progress", "dashboard"],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.cjs"
  },
  "mutate": [
    "src/services/authLockout.ts",
    "src/services/tokenBlacklist.ts",
    "src/services/alert-rules.ts",
    "src/services/apiKeys.ts",
    "src/services/cache.ts",
    "src/services/alerts.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 30000,
  "concurrency": 2,
  "disableTypeChecks": true,
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "clearTextReporter": {
    "allowColor": true,
    "logTests": true,
    "maxTestsToLog": 5
  },
  "dashboard": {
    "project": "trademind",
    "version": "main",
    "reportType": "full"
  },
  "excludedMutations": [
    "StringLiteral"
  ],
  "ignoreStatic": true
}
