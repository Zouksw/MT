# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://mt_user:mt_password@localhost:5432/mt_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=1h

# Session
SESSION_SECRET=change-this-to-a-secure-random-string

# Inference Service
INFERENCE_URL=http://localhost:10810

# Data Source API Keys (optional)
FRED_API_KEY=
OPENWEATHER_API_KEY=
MLA_API_KEY=
USDA_MARS_API_KEY=
