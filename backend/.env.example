# Backend Environment Variables
# Copy this file to .env and fill in your values.
#
# IMPORTANT — secrets (JWT_SECRET, SESSION_SECRET) MUST be regenerated for your
# environment. The values below are examples and will be rejected in production.
# Generate strong secrets with:
#   openssl rand -base64 48

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=8000
LOG_LEVEL=info
# Swagger UI at /api-docs is enabled when NODE_ENV != production OR this is "true"
SWAGGER_ENABLED=true
# Max upload size for CSV imports, in bytes (default 10MB)
IMPORT_MAX_FILE_SIZE=10485760

# ── Database (PostgreSQL) ───────────────────
# Create the DB + user first:
#   sudo -u postgres createuser mt_user --createdb
#   sudo -u postgres psql -c "ALTER USER mt_user WITH PASSWORD 'mt_password';"
#   sudo -u postgres createdb mt_db -O mt_user
DATABASE_URL=postgresql://mt_user:mt_password@localhost:5432/mt_db?schema=public

# ── Redis ───────────────────────────────────
# Either REDIS_URL (preferred) or the individual REDIS_HOST/PORT/PASSWORD vars.
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT / Auth ──────────────────────────────
# REQUIRED, >= 32 chars, non-default. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Session ─────────────────────────────────
# REQUIRED, >= 32 chars, non-default. Generate with: openssl rand -base64 48
SESSION_SECRET=

# ── CORS ────────────────────────────────────
# Comma-separated allowed origins. In development, localhost origins are allowed
# by default; set this in production to your frontend URL(s).
# CORS_ORIGIN=https://your-frontend.example.com

# ── Inference Service (Python, optional) ────
INFERENCE_URL=http://localhost:10810
INFERENCE_TIMEOUT=120000

# ── AI Feature Flags ────────────────────────
# Set AI_FEATURES_DISABLED=true to disable AI prediction routes entirely.
# AI_FEATURES_DISABLED=false
# Comma-separated IP allowlist for AI endpoints (optional).
# AI_ALLOWED_IPS=

# ── Data Ingestion ──────────────────────────
# How often (minutes) the background scrapers run. Default: 60.
# SCRAPE_INTERVAL_MINUTES=60

# ── Data Source API Keys (all optional, unlock more data) ──
FRED_API_KEY=
OPENWEATHER_API_KEY=
MLA_API_KEY=
USDA_MARS_API_KEY=
# EXCHANGE_RATE_API_URL=
# MLA_API_BASE=

# ── Email / SMTP (optional, for alert notifications) ───
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MT <noreply@example.com>"
# EMAIL_FROM=

# ── Slack (optional, for alert notifications) ───────────
# SLACK_WEBHOOK_URL=
# SLACK_CHANNEL=
