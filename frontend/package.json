{
  "name": "trademind-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "refine dev",
    "dev:public": "NODE_ENV=development refine dev",
    "build": "refine build",
    "start": "refine start",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md,css}\"",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@ant-design/nextjs-registry": "^1.0.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@refinedev/antd": "^6.0.3",
    "@refinedev/cli": "^2.16.51",
    "@refinedev/core": "^5.0.9",
    "@refinedev/devtools": "^2.0.4",
    "@refinedev/kbar": "^2.0.1",
    "@refinedev/nextjs-router": "^7.0.4",
    "antd": "^5.23.0",
    "axios": "^1.15.0",
    "dayjs": "^1.11.19",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.1",
    "lightweight-charts": "^5.1.0",
    "next": "^15.5.15",
    "next-intl": "^4.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "8",
    "@storybook/addon-essentials": "8",
    "@storybook/addon-interactions": "8",
    "@storybook/blocks": "8",
    "@storybook/builder-vite": "8",
    "@storybook/nextjs": "8",
    "@storybook/react": "8",
    "@storybook/react-vite": "8",
    "@storybook/test": "8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.2",
    "@types/node": "^20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "cross-env": "^7.0.3",
    "cross-fetch": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.13.3",
    "prettier": "^3.8.1",
    "storybook": "8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "webpack": "5"
  },
  "engines": {
    "node": ">=18.20.8"
  },
  "pnpm": {
    "overrides": {
      "handlebars": "^4.7.9",
      "path-to-regexp": "^0.1.13",
      "picomatch": "^2.3.2",
      "minimatch": "^3.1.4",
      "brace-expansion": "^1.1.13",
      "flatted": "^3.4.2",
      "glob": "^10.5.0",
      "lodash": "^4.18.0",
      "lodash-es": "^4.18.0",
      "follow-redirects": "^1.15.9",
      "vite": "^6.4.2",
      "ajv": "^8.18.0"
    }
  }
}
