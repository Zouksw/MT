{
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bcrypt": "^6.0.0",
		"@types/supertest": "^7.2.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"supertest": "^7.2.2",
		"tsx": "^4.21.0"
	},
	"pnpm": {
		"overrides": {
			"minimatch@<3.1.4": ">=3.1.4",
			"ws@<8.20.1": ">=8.20.1"
		}
	},
	"scripts": {
		"prepare": "husky",
		"restart": "./scripts/restart.sh",
		"restart:backend": "./scripts/restart.sh --backend",
		"restart:frontend": "./scripts/restart.sh --frontend",
		"stop": "lsof -ti:3000,8000,5001 2>/dev/null | xargs kill -9 2>/dev/null; echo 'All dev servers stopped'"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"biome check --write"
		]
	},
	"dependencies": {
		"pm2-logrotate": "^3.0.0"
	}
}
